<h2>
    Lista de categorias
</h2>

<hr>
<a href="/admin/categorias/add">
<button type="submit" class="btn btn-success">Nova categoria</button>
</a>

{{#each categorias}}

    <div class="card mt-4">
        <div class="card-body">
            <h4>{{nome}}</h4>
            <small>Slug: {{slug}}</small>
            <small>Data criação: {{date}}</small>
            <a href="/admin/categorias/edit/{{_id}}"><button class="btn btn-success">Editar categoria</button></a>
            <form action="/admin/categorias/deletar" method="post" style="display:inline;">
                <input type="hidden" name="id" value="{{_id}}">
                <button type="submit" class="btn btn-danger">Deletar categoria</button>
            </form>
        </div>
    </div>

{{else}}
    <h4 class="mt-4">Nenhuma categoria encontrada</h4>
{{/each}}

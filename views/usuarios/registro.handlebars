{{#each erros}}
    <div class="alert alert-danger">
        {{texto}}
    </div>
{{else}}

{{/each}}

<h3>Registro de Usuário:</h3>

<div class="card">
    <div class="card-body">
        <form action="/admin/registro/" method="POST">
            <label for="">Nome:</label>
            <input type="text" name="nome" class="form-control mb-2" required>
            <label for="">Email:</label>
            <input type="email" name="email" class="form-control" required>
            <label for="">Senha:</label>
            <input type="password" name="senha" class="form-control" required>
            <label for="">Confirme sua senha:</label>
            <input type="password" name="senha2" class="form-control" required>
            <button type="submit" class="btn btn-success mt-4">Registrar</button>
        </form>
    </div>
</div>